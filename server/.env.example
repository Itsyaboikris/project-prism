# Copy this file to .env and fill in your values.
# Never commit .env to version control.

#General
APP_BASE_URL=http://localhost:5713
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prism?sslmode=disable
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5500

#AUTH
AUTH_JWT_SECRET=dev-secret-change-me
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_INVITE_TOKEN_TTL=72h
AUTH_REFRESH_COOKIE_NAME=prism_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_COOKIE_DOMAIN=

#SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Prism Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
